. * 国有企业中的 NPR 斜率 = npr + npr#soe
. qui lincom c.npr + 1.soe#c.npr

. local b_soe  = r(estimate)

. local se_soe = r(se)

. local t_soe  = r(estimate)/r(se)

. local p_soe  = r(p)

. post `postkey' ("M3") ("NPR effect in SOE") (`b_soe') (`se_soe') (`t_soe') (`p_soe')

