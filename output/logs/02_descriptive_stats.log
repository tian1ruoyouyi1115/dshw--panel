. *----------------------------*
. * 2.1 补充：SOE vs Non-SOE t 检验
. *----------------------------*
. 
. * 关键修复：
. * 旧版在 reshape 之后继续做 t 检验，当前内存里已不是原始面板，而是汇总表，
. * 所以会报 variable lev not found。这里强制重新载入原始面板。
. use "$temp\panel_for_desc_stats.dta", clear

. 
. foreach v of local mainvars {
  2.     capture confirm variable `v'
  3.     if _rc {
  4.         di as error "变量 `v' 在原始面板中不存在，已跳过 t 检验。"
  5.         continue
  6.     }
  7. }

. capture confirm variable soe

. if _rc {
.     di as error "变量 soe 不存在，无法进行 SOE / Non-SOE t 检验。"
.     exit 111
. }

. 
. local ttest_out "$temp\ttest_soe_vs_nonsoe_temp.dta"

. cap erase "`ttest_out'"

. 
. tempname posttt

. postfile `posttt' str12 var ///
>     double mean_soe mean_nonsoe diff tstat pvalue ///
>     using "`ttest_out'", replace
(file D:\Microsoft VS Code\exP03_冯晓怡\data\temp\ttest_soe_vs_nonsoe_temp.dta not found)

. 
. foreach v of local mainvars {
  2.     capture confirm variable `v'
  3.     if _rc continue
  4. 
.     qui count if !missing(`v') & !missing(soe)
  5.     if r(N) == 0 continue
  6. 
.     qui su `v' if soe == 1, meanonly
  7.     local m1 = r(mean)
  8. 
.     qui su `v' if soe == 0, meanonly
  9.     local m0 = r(mean)
 10. 
.     capture noisily qui ttest `v', by(soe)
 11.     if _rc {
 12.         di as text ">>> `v' 的 t 检验未成功运行，已跳过。"
 13.         continue
 14.     }
 15. 
.     post `posttt' ("`v'") (`m1') (`m0') (`m1' - `m0') (r(t)) (r(p))
 16. }

. postclose `posttt'

. 
. use "`ttest_out'", clear

. gen stars = ""
(6 missing values generated)

. replace stars = "***" if pvalue < 0.01
variable stars was str1 now str3
(6 real changes made)

. replace stars = "**"  if pvalue >= 0.01 & pvalue < 0.05
(0 real changes made)

. replace stars = "*"   if pvalue >= 0.05 & pvalue < 0.10
(0 real changes made)

. 
. gen diff_star = string(diff, "%9.4f") + stars

. format mean_soe mean_nonsoe diff tstat pvalue %9.4f

. save "$tab\ttest_soe_vs_nonsoe.dta", replace
