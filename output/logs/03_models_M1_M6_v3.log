. local c_base = colnumb(bM3, "c.npr")

. local c_int  = colnumb(bM3, "1.soe#c.npr")

. 
. * Non-SOE 的 NPR 斜率
. scalar b_priv = _b[c.npr]

. scalar se_priv = sqrt(max(el(VM3, `c_base', `c_base'), 0))

. scalar t_priv = b_priv / se_priv

. scalar p_priv = 2*normal(-abs(t_priv))

. post `postkey' ("M3") ("NPR effect in NonSOE") (b_priv) (se_priv) (t_priv) (p_priv)

. 
. * SOE 的 NPR 斜率 = c.npr + 1.soe#c.npr
. scalar b_soe = _b[c.npr] + _b[1.soe#c.npr]

. scalar v_soe = el(VM3, `c_base', `c_base') + el(VM3, `c_int', `c_int') + 2*el(VM3, `c_base', `c_int')

. scalar se_soe = sqrt(max(v_soe, 0))

. scalar t_soe = b_soe / se_soe

. scalar p_soe = 2*normal(-abs(t_soe))

. post `postkey' ("M3") ("NPR effect in SOE") (b_soe) (se_soe) (t_soe) (p_soe)

. 
. * 交互项显著性 = 差异检验
. scalar b_diff = _b[1.soe#c.npr]

. scalar se_diff = sqrt(max(el(VM3, `c_int', `c_int'), 0))

. scalar t_diff = b_diff / se_diff

. scalar p_diff = 2*normal(-abs(t_diff))

. post `postkey' ("M3") ("Diff test: interaction") (b_diff) (se_diff) (t_diff) (p_diff)

