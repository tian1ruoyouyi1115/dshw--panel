. * 正式差异检验：交互项是否显著
. qui test 1.soe#c.npr = 0

. local p_diff = r(p)

. local F_diff = r(F)

. post `postkey' ("M3") ("Diff test: interaction") (`F_diff') (.) (.) (`p_diff')

