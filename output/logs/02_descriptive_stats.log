. *====================================================*
. * Part 2.2 相关系数矩阵
. *====================================================*
. 
. local K : word count `corrvars'

. matrix C = J(`K', `K', .)

. matrix P = J(`K', `K', .)

. 
. local i = 1

. foreach x of local corrvars {
  2.     local j = 1
  3.     foreach y of local corrvars {
  4.         if `i' == `j' {
  5.             matrix C[`i', `j'] = 1
  6.             matrix P[`i', `j'] = .
  7.         }
  8.         else {
  9.             qui corr `x' `y' if !missing(`x', `y')
 10.             matrix R = r(C)
 11.             scalar rho = R[1,2]
 12. 
.             qui count if !missing(`x', `y')
 13.             scalar n = r(N)
 14. 
.             scalar p = .
 15.             if n > 2 & abs(rho) < 1 {
 16.                 scalar tval = rho * sqrt((n - 2) / (1 - rho^2))
 17.                 scalar p = 2 * ttail(n - 2, abs(tval))
 18.             }
 19. 
.             matrix C[`i', `j'] = rho
 20.             matrix P[`i', `j'] = p
 21.         }
 22.         local ++j
 23.     }
 24.     local ++i
 25. }

. 
. matrix rownames C = `corrvars'

. matrix colnames C = `corrvars'

. matrix rownames P = `corrvars'

. matrix colnames P = `corrvars'

