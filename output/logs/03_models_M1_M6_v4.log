. * 为确保 Fig7 一定生成：手工计算 threshold profile LR path
. qui su size, detail

. local q05 = r(p5)

. local q95 = r(p95)

. local ngr = 100

. 
. tempfile m6profile

. tempname postm6

. postfile `postm6' double gamma ssr using `m6profile', replace
(file C:\Users\Phyllis\AppData\Local\Temp\ST_10e8_000006.tmp not found)

. 
. tempvar npr_low npr_high __thr_resid __thr_sq

. gen double `npr_low'  = .
(15,828 missing values generated)

. gen double `npr_high' = .
(15,828 missing values generated)

. 
. forvalues i = 0/`ngr' {
  2.     local g = `q05' + (`q95' - `q05') * `i' / `ngr'
  3. 
.     quietly replace `npr_low'  = npr * (size <= `g')
  4.     quietly replace `npr_high' = npr * (size >  `g')
  5. 
.     * 这里只需要 SSR profile，不需要聚类方差，因此不加 vce() 更稳更快
.     capture noisily qui reghdfe lev `npr_low' `npr_high' tang growth ndts, ///
>         absorb(firmid year)
  6. 
.     if !_rc {
  7.         local got_rss = 1
  8.         capture scalar ssr_cur = e(rss)
  9.         if _rc local got_rss = 0
 10. 
.         if `got_rss' == 0 {
 11.             capture drop `__thr_resid' `__thr_sq'
 12.             quietly predict double `__thr_resid' if e(sample), resid
 13.             quietly gen double `__thr_sq' = `__thr_resid'^2 if e(sample)
 14.             quietly su `__thr_sq', meanonly
 15.             scalar ssr_cur = r(sum)
 16.             capture drop `__thr_resid' `__thr_sq'
 17.         }
 18. 
.         if ssr_cur < . {
 19.             post `postm6' (`g') (ssr_cur)
 20.         }
 21.     }
 22. }

. 
. capture drop `npr_low' `npr_high' `__thr_resid' `__thr_sq'

. postclose `postm6'

. 
. 
. use `m6profile', clear

. drop if missing(gamma) | missing(ssr)
