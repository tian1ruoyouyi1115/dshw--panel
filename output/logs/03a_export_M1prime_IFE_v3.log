. * ---------- 6. 导出关键系数到 Excel ----------
. putexcel set "$tab\M1prime_ife_key_results.xlsx", replace
Note: File will be replaced when the first putexcel command is issued.

. putexcel A1 = "Model" B1 = "Variable" C1 = "Coef" D1 = "SE" E1 = "t_or_z" F1 = "pvalue" G1 = "Sig"
file D:\Microsoft VS Code\exP03_冯晓怡\output\tables\M1prime_ife_key_results.xlsx saved

. 
. local row = 2

. foreach mdl in M1 M1prime_IFE {
  2.     estimates restore `mdl'
  3.     matrix b = e(b)
  4.     matrix V = e(V)
  5.     local cn : colfullnames b
  6. 
.     foreach x in npr m2_growth size tang growth ndts {
  7.         local pos = colnumb(b, "`x'")
  8.         if !missing(`pos') {
  9.             scalar __coef = b[1,`pos']
 10.             scalar __se   = sqrt(V[`pos',`pos'])
 11.             scalar __t    = __coef/__se
 12.             scalar __p    = 2*normal(-abs(__t))
 13.             local sig = cond(__p<0.01,"***", cond(__p<0.05,"**", cond(__p<0.10,"*","")))
 14.             putexcel A`row' = "`mdl'" B`row' = "`x'" C`row' = (__coef) D`row' = (__se) E`row' = (__t) F`row' = (__p) G`row' = "`sig'"
 15.             local ++row
 16.         }
 17.     }
 18. }
