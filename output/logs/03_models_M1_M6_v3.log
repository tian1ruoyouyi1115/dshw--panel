. forvalues i = 0/`ngr' {
  2.     local g = `q05' + (`q95' - `q05') * `i' / `ngr'
  3. 
.     capture drop npr_low npr_high __thr_resid __thr_sq
  4.     gen double npr_low  = npr * (size <= `g')
  5.     gen double npr_high = npr * (size >  `g')
  6. 
.     capture noisily qui reghdfe lev npr_low npr_high tang growth ndts, ///
>         absorb(firmid year) ///
>         vce(cluster firmid year)
  7. 
.     if !_rc {
  8.         local got_rss = 1
  9.         capture scalar ssr_cur = e(rss)
 10.         if _rc local got_rss = 0
 11. 
.         if `got_rss' == 0 {
 12.             capture drop __thr_resid __thr_sq
 13.             predict double __thr_resid if e(sample), resid
 14.             gen double __thr_sq = __thr_resid^2 if e(sample)
 15.             qui su __thr_sq, meanonly
 16.             scalar ssr_cur = r(sum)
 17.         }
 18. 
.         if ssr_cur < . {
 19.             post `postm6' (`g') (ssr_cur)
 20.         }
 21.     }
