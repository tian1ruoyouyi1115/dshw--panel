. global root  "D:\Microsoft VS Code\exP03_冯晓怡"

. global clean "$root\data\clean"

. global temp  "$root\data\temp"

. global out   "$root\output"

. global tab   "$out\tables"

. global fig   "$out\figures"

. global log   "$out\logs"

. 
. cap mkdir "$temp"

. cap mkdir "$out"

. cap mkdir "$tab"

. cap mkdir "$fig"

. cap mkdir "$log"

. 
. capture confirm file "$clean\panel_clean_for_analysis.dta"

. if _rc {
.     di as error "未找到输入文件：$clean\panel_clean_for_analysis.dta"
.     di as error "请先成功运行 01_build_panel_from_raw_v4.do"
.     exit 601
. }

